# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* for app + app.config).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sign-In (same project as consumer app is fine; use a dedicated OAuth client for Business if you prefer).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# iOS OAuth client id (numeric-project-id-xxx.apps.googleusercontent.com or just the id prefix before .apps...)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
