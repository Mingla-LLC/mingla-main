# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* for app + app.config).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sign-In — must match Supabase Dashboard → Authentication → Providers → Google → Client IDs.
# Use a comma-separated list there: Web Application client ID first, then this app’s iOS client, then
# Android OAuth client IDs (debug + release SHA-1) if needed. If any `aud` in the ID token is missing
# from that list, Supabase returns: "Unacceptable audience in id_token".
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# iOS OAuth client for this app’s bundle ID (full ...apps.googleusercontent.com string).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
