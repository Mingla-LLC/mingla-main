# Google Maps (iOS/Android native SDK + Places API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox (travel time + traffic via Directions API)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Analytics — Mixpanel (behavioral tracking, funnels, retention)
# Get token from: Mixpanel dashboard → Project Settings → Access Keys → Token
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token

# Google OAuth (these are client IDs, less sensitive but still externalized)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id_here
GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id_here
