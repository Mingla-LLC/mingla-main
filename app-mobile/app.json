{
  "expo": {
    "name": "Mingla",
    "slug": "mingla-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "com.mingla.app",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9fa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mingla.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mingla needs location access to find experiences near you and provide location-based recommendations.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mingla needs location access to find experiences near you and provide location-based recommendations.",
        "NSLocationAlwaysUsageDescription": "Mingla needs location access to find experiences near you and provide location-based recommendations.",
        "NSCameraUsageDescription": "Mingla needs camera access to capture photos for your experiences.",
        "NSPhotoLibraryUsageDescription": "Mingla needs photo library access to select images for your experiences."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f8f9fa"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mingla.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-camera",
      "expo-calendar",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.6s9rtipm8n1t74p2n9c2bqklbsek0p-899330368277"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "4c431435-9cff-45cd-a670-e898fb9f00a7"
      }
    }
  }
}
