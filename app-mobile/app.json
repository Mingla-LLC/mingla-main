      "EXPO_PUBLIC_OPENWEATHER_API_KEY": "299d1497ef6fbdb0c63f1606ddfc72f9",
      "EXPO_PUBLIC_FOURSQUARE_API_KEY": "RXN0EIVNOQ1MMLL2XXQGLXWEYV0YB53ELZECFGHQ5GZM2VW0",
      "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaSyDqDfjlRxbpNvV3J20rK6YSfC0NWkpFsS4",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "618060733220-l9ls35bklsvlqbj7ii9v5tiok9neqhee.apps.googleusercontent.com",
      "ANDROID_CLIENT_ID": "618060733220-hvlvia73dcm2sd5hgbvnp59bnas46gt0.apps.googleusercontent.com",
