{
  "expo": {
    "name": "Mingla",
    "slug": "mingla-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "com.mingla.app.v2",
